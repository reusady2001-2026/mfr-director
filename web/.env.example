# ── Claude API ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Security ──────────────────────────────────────────────────────────────────
# Long random string — used to sign JWT sessions AND generate monthly codes.
# Changing this value invalidates all existing sessions and rotates all codes.
SECRET_KEY=change-me-use-a-long-random-string-here

# Admin key for the /admin/* endpoints (add/remove subscribers)
ADMIN_KEY=your-admin-secret

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sender@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=MFR Director <your-sender@gmail.com>

# ── Google Sheets Export (optional) ──────────────────────────────────────────
# Path to service account JSON key file
GOOGLE_SERVICE_ACCOUNT_JSON=/app/service-account.json
# OR paste the raw JSON content as a single-line string:
# GOOGLE_SERVICE_ACCOUNT_JSON_CONTENT={"type":"service_account",...}

# ── HTTPS ─────────────────────────────────────────────────────────────────────
# Set to "true" when running behind HTTPS to mark session cookie as secure
HTTPS=false
